{
  "name": "react-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next build && next start -p 3000", 
    "git-hooks-install": "husky install",
    "storybook-start": "storybook dev -p 6006",
    "storybook-build": "storybook build",
    "generate-ts-doc": "api-extractor run --local --verbose",
    "format": "prettier . --write",
    "lint:next": "eslint",
    "lint:tsc": "tsc",
    "lint:md": "markdownlint -i CHANGELOG.md **/*.md",
    "test:e2e": "cypress run --headless --browser chrome",
    "test:e2e-local": "cypress open",
    "test:unit": "jest --verbose",
    "test:memory-leak": "memlab run -v --scenario ./memlab/memoryLeakTest.js",
    "lighthouse:desktop": "next build && lhci autorun --config=lighthouserc.desktop.cjs --collect.startServerCommand=\"npx serve@latest out\"",
    "lighthouse:mobile": "next build && lhci autorun --config=lighthouserc.mobile.cjs --collect.startServerCommand=\"npx serve@latest out\"",
    "check-node-version": "node checkNodeVersion.js",
    "preinstall": "pnpm run check-node-version",
    "screenshot": "node scripts/screenshot.js"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@mui/icons-material": "^7.3.8",
    "@mui/lab": "7.0.1-beta.22",
    "@mui/material": "^7.3.8",
    "@mui/material-nextjs": "^7.3.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/node": "^10.40.0",
    "@sentry/react": "^10.40.0",
    "@testing-library/dom": "^10.4.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.0",
    "i18next": "^25.8.13",
    "jest": "^30.2.0",
    "jsdoc": "^4.0.5",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "next-fonts": "^1.5.1",
    "react": "^19.2.4",
    "react-apexcharts": "^2.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-redux": "^9.2.0",
    "reflect-metadata": "^0.2.2",
    "require-from-string": "^2.0.2",
    "simplebar-react": "^3.3.2",
    "storybook": "^8.6.17",
    "terser-webpack-plugin": "^5.3.16",
    "tsyringe": "^4.10.0",
    "web-vitals": "^4.2.4",
    "webpack": "^5.105.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^3.2.7",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@lhci/cli": "^0.15.1",
    "@microsoft/api-extractor": "^7.57.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@storybook/addon-actions": "^8.6.17",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.17",
    "@storybook/addon-webpack5-compiler-babel": "3.0.6",
    "@storybook/nextjs": "8.6.12",
    "@storybook/react": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "@testing-library/react": "^16.3.2",
    "@toolpad/core": "^0.16.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-loader": "^10.0.0",
    "eslint": "^9.39.3",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^0.12.0",
    "eslint-plugin-testing-library": "^7.16.0",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.47.0",
    "memlab": "^2.0.0",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "semver": "^7.7.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "engineStrict": true
}
